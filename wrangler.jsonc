{
  // Cloudflare Workers config for the OpenNext build.
  // Deploy: pnpm dlx @opennextjs/cloudflare build && pnpm dlx wrangler deploy
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "accreditgenius",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-03-01",
  // Node built-ins used by pdf-parse / docx / crypto.
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // R2 bucket for uploaded/generated files (StorageProvider "s3" driver).
  "r2_buckets": [
    {
      "binding": "UPLOADS",
      "bucket_name": "accreditgenius-uploads"
    }
  ],
  // Drain the DB-backed job queue every minute (safety net for retries).
  "triggers": {
    "crons": ["* * * * *"]
  },
  "observability": {
    "enabled": true
  }
  // Secrets (DATABASE_URL, AUTH_SECRET, ANTHROPIC_API_KEY, S3_*, …) are set
  // via `wrangler secret put` or the dashboard — never commit them.
}

# Copy to .env and fill in values.

# PostgreSQL with pgvector + pg_trgm extensions enabled
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accreditgenius"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — credentials login works without it)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Anthropic API (generation, review, embeddings pipeline)
ANTHROPIC_API_KEY=""

# Storage: "local" (dev) | "s3" (later, via StorageProvider)
STORAGE_DRIVER="local"
UPLOADS_DIR="./uploads"

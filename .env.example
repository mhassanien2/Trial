# Copy to .env and fill in values.

# PostgreSQL with pgvector + pg_trgm extensions enabled
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/accreditgenius"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (optional — credentials login works without it)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Anthropic API (generation, review). Optional — features degrade gracefully.
ANTHROPIC_API_KEY=""

# Embeddings provider (optional). Auto-selects: voyage → openai → local dev.
# EMBEDDINGS_PROVIDER="voyage"   # or "openai" | "local"
VOYAGE_API_KEY=""
OPENAI_API_KEY=""

# Storage: "local" (dev) | "s3" (S3 / Cloudflare R2)
STORAGE_DRIVER="local"
UPLOADS_DIR="./uploads"

# S3 / R2 (only when STORAGE_DRIVER=s3)
S3_ENDPOINT=""            # e.g. https://<accountid>.r2.cloudflarestorage.com
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"

# Background job runner: bearer token for POST /api/jobs/run (external cron)
JOBS_RUN_SECRET=""
